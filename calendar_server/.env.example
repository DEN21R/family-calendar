PORT=3333
HOST=http://127.0.0.1
MONGO_URI=mongodb://localhost:27017/calendar_data
JWT_SECRET=replace_this_with_a_long_random_secret

# SMTP settings for email reminders
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Family Calendar <your_email@gmail.com>"

# Optional diagnostics mode for strict recipient filtering domains.
# true: sends plain-text only, prefixes subject, and can BCC another mailbox.
EMAIL_DIAGNOSTIC_MODE=false
EMAIL_DIAGNOSTIC_BCC=
EMAIL_DIAGNOSTIC_SUBJECT_PREFIX=[DIAG]

# Frontend URL used in emails
APP_URL=http://localhost:5173

# Optional fallback timezone for legacy tasks that don't have timeZone saved yet
# Example: Europe/Kyiv
DEFAULT_TIME_ZONE=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
